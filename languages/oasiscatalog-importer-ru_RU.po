#: oasiscatalog-importer.php:354
msgid "Setting up import of Oasis products"
msgstr "Настройка импорта товаров Oasis"

#: oasiscatalog-importer.php:240
msgid "Launch settings"
msgstr "Настройка запуска"

#: oasiscatalog-importer.php:292
msgid "Key API"
msgstr "Ключ API"

#: oasiscatalog-importer.php:303
msgid "API User ID"
msgstr "ID пользователя"

#: oasiscatalog-importer.php:225
msgid "Specify the API key!"
msgstr "Укажите API ключ!"

#: oasiscatalog-importer.php:232
msgid "API key is invalid"
msgstr "API ключ не верный"

#: oasiscatalog-importer.php:360
msgid "Currency"
msgstr "Валюта"

#: oasiscatalog-importer.php:373
#: oasiscatalog-importer.php:810
msgid "Categories"
msgstr "Категории"

#: oasiscatalog-importer.php:429
msgid "Do not update categories"
msgstr "Не обновлять категории"

#: oasiscatalog-importer.php:450
msgid "No VAT"
msgstr "Без НДС"

#: oasiscatalog-importer.php:457
msgid "Without goods \"to order\""
msgstr "Без товаров \"под заказ\""

#: oasiscatalog-importer.php:464
msgid "Price from"
msgstr "Цена от"

#: oasiscatalog-importer.php:471
msgid "Price to"
msgstr "Цена до"

#: oasiscatalog-importer.php:478
msgid "Type"
msgstr "Тип"

#: oasiscatalog-importer.php:494
msgid "Type of grouping"
msgstr "Тип группировки"

#: oasiscatalog-importer.php:498
msgid "Default"
msgstr "По умолчанию"

#: oasiscatalog-importer.php:499
msgid "By color"
msgstr "По цвету"

#: oasiscatalog-importer.php:501
msgid "By default, products are grouped by color and size (for example, a T-shirt with color and size options)"
msgstr "По умолчанию товар группируется по цвету и размеру (например футболка с вариантами цвета и размера)"

#: oasiscatalog-importer.php:502
msgid "ATTENTION! It is recommended to change this option before importing products. If you change it afterward, all current Oasis products will be deleted and re-uploaded"
msgstr "ВНИМАНИЕ! Опцию рекомендуется менять до импорта товаров. Если изменить после, все текущие продукты Oasis будут удалены и загружены заново"

#: oasiscatalog-importer.php:510
msgid "Without a remote warehouse"
msgstr "Без удаленного склада"

#: oasiscatalog-importer.php:339
msgid "Limit products"
msgstr "Лимит товаров"

#: oasiscatalog-importer.php:340
msgid "The number of products received from the API and processed in one run."
msgstr "Количество товаров получаемое из API и обрабатываемое за один запуск."

#: oasiscatalog-importer.php:540
msgid "Price settings"
msgstr "Настройки цен"

#: oasiscatalog-importer.php:546
msgid "Price factor"
msgstr "Коэффициент цены"

#: oasiscatalog-importer.php:547
msgid "The price will be multiplied by this factor. For example, in order to increase the cost by 20%, you need to specify 1.2"
msgstr "Цена будет умножена на данный коэффициент. Например, для того чтобы увеличить стоимость на 20% необходимо указать 1,2"

#: oasiscatalog-importer.php:553
msgid "Add to price"
msgstr "Добавить к цене"

#: oasiscatalog-importer.php:554
msgid "This value will be added to the price. For example, if you specify 100, then 100 will be added to the cost of all products."
msgstr "К цене будет добавлена данная величина. Например, если указать 100, то у всех товаров к стоимости будет добавлено 100."

#: oasiscatalog-importer.php:560
msgid "Use dealer prices"
msgstr "Использовать диллерские цены"

#: oasiscatalog-importer.php:568
msgid "Additional settings"
msgstr "Дополнительные настройки"

#: oasiscatalog-importer.php:574
msgid "Enable reviews"
msgstr "Включить отзывы"

#: oasiscatalog-importer.php:575
msgid "Enable commenting on imported products"
msgstr "Включить комментирование импортируемых товаров"

#: oasiscatalog-importer.php:588
msgid "Hide discounts"
msgstr "Скрыть скидки"

#: oasiscatalog-importer.php:589
msgid "Hide \"old\" price in products"
msgstr "Скрыть \"старую\" цену в товарах"

#: oasiscatalog-importer.php:595
msgid "Widget branding"
msgstr "Виджет нанесения"

#: oasiscatalog-importer.php:596
msgid "Enable branding widget on checkout page"
msgstr "Включить виджет нанесения на странице оформления заказа"

#: oasiscatalog-importer.php:602
msgid "Up photo"
msgstr "Обновление фото"

#: oasiscatalog-importer.php:603
msgid "Force product photos to be updated (slows down the plugin)"
msgstr "Принудительно обновлять фото товаров (замедляет работу плагина)"

#: oasiscatalog-importer.php:609
msgid "Use CDN image server"
msgstr "Использовать CDN сервер изображений"

#: oasiscatalog-importer.php:610
msgid "Display product photos without uploading, saves space on hosting. May not work correctly with some themes and plugins"
msgstr "Отображать фото товаров без загрузки, экономит место на хостинге. Возможна некорректная работа с некоторыми темами и плагинами"

#: oasiscatalog-importer.php:295
msgid "After specifying the key, it will be possible to configure the import of products into Woocommerce from the Oasis website"
msgstr "После указания ключа можно будет настроить импорт товаров в Woocommerce с сайта Oasis"

#: oasiscatalog-importer.php:306
msgid "After specifying the user id, it will be possible to upload orders to Oasis"
msgstr "После указания user id можно будет выгружать заказы в Oasis"

#: oasiscatalog-importer.php:482
msgid "---Select---"
msgstr "---Выбирать---"

#: oasiscatalog-importer.php:483
msgid "Only new items"
msgstr "Только новинки"

#: oasiscatalog-importer.php:484
msgid "Only hits"
msgstr "Только хиты"

#: oasiscatalog-importer.php:485
msgid "Discount only"
msgstr "Только со скидкой"

#: oasiscatalog-importer.php:192
#: oasiscatalog-importer.php:193
msgid "Oasis Import"
msgstr "Оазис импорт"

#: oasiscatalog-importer.php:722
msgid "Settings saved"
msgstr "Настройки сохранены"

#: oasiscatalog-importer.php:744
#: oasiscatalog-importer.php:877
msgid "Loading..."
msgstr "Загрузка..."

#: oasiscatalog-importer.php:743
msgid "General processing status"
msgstr "Общий статус обработки"

#: oasiscatalog-importer.php:253
msgid "Download / update products 1 time per day"
msgstr "Загрузка/обновление товаров 1 раз в сутки"

#: oasiscatalog-importer.php:258
#: oasiscatalog-importer.php:271
msgid "Copy"
msgstr "Копировать"

#: oasiscatalog-importer.php:266
msgid "Renewal of balances 1 time in 2 hours"
msgstr "Обновление остатков 1 раз в 2 часа"

#: oasiscatalog-importer.php:801
msgid "Save settings"
msgstr "Сохранить настройки"

#: oasiscatalog-importer.php:815
msgid "Clear"
msgstr "Очистить"

#: oasiscatalog-importer.php:816
msgid "Select"
msgstr "Выбрать"

#: oasiscatalog-importer.php:849
msgid "Settings"
msgstr "Настройки"

