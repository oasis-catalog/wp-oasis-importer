#: src/order.php:55
#: src/order.php:59
msgid "Unload"
msgstr "Выгрузить"

#: src/order.php:42
msgid "Invalid items in the order"
msgstr "В заказе недопустимые товары"

#: src/order.php:53
msgid "The order is being processed, please wait."
msgstr "Заказ обрабатывается, ожидайте."

#: src/order.php:55
msgid "Error, please try again."
msgstr "Ошибка, попробуйте еще раз."

#: oasiscatalog-importer.php:414
msgid "Default category"
msgstr "Категория по умолчанию"

#: oasiscatalog-importer.php:419
msgid "If no link is specified for a product category, the product will be placed in the default category"
msgstr "Если для категории товара не указана связь, товар будет помещен в категорию по умолчанию"

#: oasiscatalog-importer.php:346
msgid "Do not limit update"
msgstr "Не ограничивать обновление"

#: oasiscatalog-importer.php:347
msgid "Full product update is limited, no more than once a day"
msgstr "Полное обновление товаров ограничено, не чаще раз в день"

#: oasiscatalog-importer.php:581
msgid "Enable brands"
msgstr "Включить бренды"

#: oasiscatalog-importer.php:582
msgid "Enable brands on imported products"
msgstr "Включить бренды импортируемых товаров"

#: oasiscatalog-importer.php:616
msgid "Quick import of products"
msgstr "Быстрый импорт товаров"

#: oasiscatalog-importer.php:617
msgid "Import without photos. After a full upload of all products, the option is turned off"
msgstr "Импорт без фотографий. После полновый загрузки всех товаров, опция отключается"

#: oasiscatalog-importer.php:623
msgid "Remove quotes"
msgstr "Удалять кавычки"

#: oasiscatalog-importer.php:624
msgid "Remove quotes in the title"
msgstr "Удалять кавычки в названии"

#: oasiscatalog-importer.php:436
msgid "No defective goods"
msgstr "Без товаров с дефектом"

#: oasiscatalog-importer.php:443
msgid "All remaining products"
msgstr "Все остатки товаров"

#: oasiscatalog-importer.php:444
msgid "Show products that are no longer available (clearance sale)"
msgstr "Показывать товары, которые больше не поставляется (распродажа остатков)"

