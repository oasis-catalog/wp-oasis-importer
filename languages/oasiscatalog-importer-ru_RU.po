#: oasiscatalog-importer.php:466
msgid "If no link is specified for a product category, the product will be placed in the default category"
msgstr "Если для категории товара не указана связь, товар будет помещен в категорию по умолчанию"

#: oasiscatalog-importer.php:393
msgid "Do not limit update"
msgstr "Не ограничивать обновление"

#: oasiscatalog-importer.php:394
msgid "Full product update is limited, no more than once a day"
msgstr "Полное обновление товаров ограничено, не чаще раз в день"

#: oasiscatalog-importer.php:604
msgid "Enable brands"
msgstr "Включить бренды"

#: oasiscatalog-importer.php:605
